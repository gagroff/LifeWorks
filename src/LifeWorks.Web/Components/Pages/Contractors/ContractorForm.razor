@page "/contractors/new"
@page "/contractors/{Id:guid}/edit"
@inject IContractorService ContractorService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>@(_isEditMode ? "Edit Contractor" : "New Contractor")</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@(_isEditMode ? "Edit Contractor" : "New Contractor")</MudText>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />

        <MudGrid>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_model.Name"
                              Label="Name"
                              Required="true"
                              For="() => _model.Name"
                              Class="mb-3" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_model.CompanyName"
                              Label="Company Name"
                              For="() => _model.CompanyName"
                              Class="mb-3" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_model.Phone"
                              Label="Phone"
                              For="() => _model.Phone"
                              Class="mb-3" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudTextField @bind-Value="_model.Email"
                              Label="Email"
                              For="() => _model.Email"
                              Class="mb-3" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_model.Website"
                              Label="Website"
                              For="() => _model.Website"
                              Class="mb-3" />
            </MudItem>

            <MudItem xs="12" md="6">
                <MudAutocomplete T="string"
                                 @bind-Value="_model.Trade"
                                 Label="Trade / Specialty"
                                 SearchFunc="SearchTradesAsync"
                                 CoerceText="true"
                                 For="() => _model.Trade"
                                 Class="mb-3" />
            </MudItem>
            <MudItem xs="12" md="6">
                <MudField Label="Rating" Class="mb-3">
                    <MudRating @bind-SelectedValue="_ratingValue" MaxValue="5" />
                </MudField>
            </MudItem>

            <MudItem xs="12">
                <MudSwitch @bind-Value="_model.IsFavorite"
                           Label="Mark as Trusted Vendor"
                           Color="Color.Warning"
                           Class="mb-3" />
            </MudItem>

            <MudItem xs="12">
                <MudTextField @bind-Value="_model.Notes"
                              Label="Notes"
                              For="() => _model.Notes"
                              Lines="4"
                              Class="mb-3" />
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Spacing="2" Class="mt-4">
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary">
                Save
            </MudButton>
            <MudButton Variant="Variant.Text"
                       OnClick="BackToList">
                Cancel
            </MudButton>
        </MudStack>
    </EditForm>
}

@code {
    [Parameter]
    public Guid? Id { get; set; }

    private Contractor _model = new();
    private bool _loading = true;
    private bool _isEditMode;
    private List<string> _trades = [];
    private int _ratingValue;

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _isEditMode = Id.HasValue;
        _trades = await ContractorService.GetDistinctTradesAsync();

        if (_isEditMode)
        {
            var existing = await ContractorService.GetByIdAsync(Id!.Value);
            if (existing is null)
            {
                Snackbar.Add("Contractor not found.", Severity.Error);
                Navigation.NavigateTo("/contractors");
                return;
            }

            _model = existing;
            _ratingValue = existing.Rating ?? 0;
        }
        else
        {
            _model = new Contractor();
            _ratingValue = 0;
        }

        _loading = false;
    }

    private Task<IEnumerable<string>> SearchTradesAsync(string? value, CancellationToken _)
    {
        var results = string.IsNullOrWhiteSpace(value)
            ? _trades
            : _trades.Where(t => t.Contains(value, StringComparison.OrdinalIgnoreCase)).ToList();
        return Task.FromResult<IEnumerable<string>>(results);
    }

    private async Task SaveAsync()
    {
        _model.Rating = _ratingValue > 0 ? _ratingValue : null;

        if (_isEditMode)
        {
            await ContractorService.UpdateAsync(_model);
            Snackbar.Add("Contractor updated", Severity.Success);
        }
        else
        {
            await ContractorService.AddAsync(_model);
            Snackbar.Add("Contractor added", Severity.Success);
        }

        Navigation.NavigateTo("/contractors");
    }

    private void BackToList()
    {
        Navigation.NavigateTo("/contractors");
    }
}
