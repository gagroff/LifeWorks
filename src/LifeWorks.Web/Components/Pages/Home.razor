@page "/"
@inject IHomeImprovementService HomeImprovementService
@inject IAssetService AssetService
@inject IMaintenanceService MaintenanceService

<PageTitle>LifeWorks</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>

@if (_loading)
{
    <MudGrid>
        @for (int i = 0; i < 3; i++)
        {
            <MudItem xs="12" sm="4">
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="100px" />
            </MudItem>
        }
    </MudGrid>
}
else
{
    @* ── Summary Stats ── *@
    <MudGrid Class="mb-6">
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.Build" Color="Color.Primary" Size="Size.Large" Class="mb-1" />
                <MudText Typo="Typo.h4">@_totalCount</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Improvements</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.AttachMoney" Color="Color.Success" Size="Size.Large" Class="mb-1" />
                <MudText Typo="Typo.h4">@_totalSpend.ToString("C0")</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Total Spend (All Time)</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-4 d-flex flex-column align-center" Elevation="2">
                <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Warning" Size="Size.Large" Class="mb-1" />
                <MudText Typo="Typo.h4">@_expiringWarrantyItems.Count</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">Warranties Expiring (90 days)</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudGrid>
        @* ── Cost by Property ── *@
        <MudItem xs="12" md="4">
            <MudText Typo="Typo.h6" Class="mb-2">Spend by Property</MudText>
            @if (_costByProperty.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No data yet.</MudText>
            }
            else
            {
                @foreach (var (propertyName, totalCost) in _costByProperty)
                {
                    <MudPaper Class="pa-3 mb-2" Elevation="1">
                        <MudText Typo="Typo.subtitle2">@propertyName</MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary">@totalCost.ToString("C0")</MudText>
                    </MudPaper>
                }
            }
        </MudItem>

        @* ── Cost by Category Chart ── *@
        <MudItem xs="12" md="8">
            <MudText Typo="Typo.h6" Class="mb-2">Spend by Category</MudText>
            @if (_costByCategory.Count == 0)
            {
                <MudText Typo="Typo.body2" Color="Color.Secondary">No data yet.</MudText>
            }
            else
            {
                <MudChart ChartType="ChartType.Bar"
                          ChartSeries="_categorySeries"
                          ChartLabels="_categoryLabels"
                          Width="100%"
                          Height="300px" />
            }
        </MudItem>

        @* ── Warranty Alerts ── *@
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h6" Class="mb-2">Warranty Alerts</MudText>
            @if (_expiringWarrantyItems.Count == 0)
            {
                <MudPaper Class="pa-3" Elevation="1">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No warranties expiring in the next 90 days.</MudText>
                </MudPaper>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var item in _expiringWarrantyItems)
                    {
                        var daysLeft = item.WarrantyExpiration.DayNumber - DateOnly.FromDateTime(DateTime.Today).DayNumber;
                        var chipColor = daysLeft < 0 ? Color.Error : daysLeft <= 30 ? Color.Warning : Color.Success;
                        var label = daysLeft < 0 ? "Expired" : daysLeft == 0 ? "Today" : $"{daysLeft}d left";
                        <MudListItem>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudLink Href="@item.LinkHref">@item.Title</MudLink>
                                    <MudChip T="string" Color="Color.Info" Variant="Variant.Outlined" Size="Size.Small">@item.Source</MudChip>
                                </MudStack>
                                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.PropertyName</MudText>
                                    <MudChip T="string" Color="@chipColor" Size="Size.Small">@label</MudChip>
                                </MudStack>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudItem>

        @* ── Maintenance Due ── *@
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h6" Class="mb-2">Maintenance Due</MudText>
            @if (_maintenanceDue.Count == 0)
            {
                <MudPaper Class="pa-3" Elevation="1">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Nothing due in the next 30 days.</MudText>
                </MudPaper>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var item in _maintenanceDue)
                    {
                        var days = item.NextDue.DayNumber - DateOnly.FromDateTime(DateTime.Today).DayNumber;
                        var chipColor = days < 0 ? Color.Error : days <= 14 ? Color.Warning : Color.Success;
                        var label = days < 0 ? "Overdue" : days == 0 ? "Today" : $"{days}d";
                        <MudListItem>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <div>
                                    <MudLink Href="@($"/maintenance/{item.Task.Id}")">@item.Task.Title</MudLink>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Task.Property.Name · Next @item.NextDue.ToString("MM/dd/yyyy")</MudText>
                                </div>
                                <MudChip T="string" Color="@chipColor" Size="Size.Small">@label</MudChip>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudItem>

        @* ── Recent Activity ── *@
        <MudItem xs="12" md="6">
            <MudText Typo="Typo.h6" Class="mb-2">Recent Activity</MudText>
            @if (_recentImprovements.Count == 0)
            {
                <MudPaper Class="pa-3" Elevation="1">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">No improvements recorded yet.</MudText>
                </MudPaper>
            }
            else
            {
                <MudList T="string" Dense="true">
                    @foreach (var item in _recentImprovements)
                    {
                        <MudListItem>
                            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                                <div>
                                    <MudLink Href="@($"/improvements/{item.Id}")">@item.Title</MudLink>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">@item.Property?.Name · @item.DateCompleted.ToString("MM/dd/yyyy")</MudText>
                                </div>
                                @if (item.Cost.HasValue)
                                {
                                    <MudText Typo="Typo.body2">@item.Cost.Value.ToString("C0")</MudText>
                                }
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
        </MudItem>
    </MudGrid>
}

@code {
    private bool _loading = true;

    private int _totalCount;
    private decimal _totalSpend;

    private List<(string PropertyName, decimal TotalCost)> _costByProperty = [];
    private List<(string CategoryName, decimal TotalCost)> _costByCategory = [];
    private List<HomeImprovement> _expiringImprovementWarranties = [];
    private List<Asset> _expiringAssetWarranties = [];
    private List<WarrantyAlertItem> _expiringWarrantyItems = [];
    private List<HomeImprovement> _recentImprovements = [];
    private List<MaintenanceDueItem> _maintenanceDue = [];

    private List<ChartSeries<double>> _categorySeries = [];
    private string[] _categoryLabels = [];

    protected override async Task OnInitializedAsync()
    {
        var improvements = await HomeImprovementService.GetAllAsync();
        _totalCount = improvements.Count;
        _totalSpend = await HomeImprovementService.GetTotalCostAsync();

        _costByProperty = await HomeImprovementService.GetCostByPropertyAsync();
        _costByCategory = await HomeImprovementService.GetCostByCategoryAsync();
        _expiringImprovementWarranties = await HomeImprovementService.GetExpiringWarrantiesAsync(90);
        _expiringAssetWarranties = await AssetService.GetExpiringWarrantiesAsync(90);
        _expiringWarrantyItems =
        [
            .. _expiringImprovementWarranties
                .Where(i => i.WarrantyExpiration.HasValue)
                .Select(i => new WarrantyAlertItem(
                    i.WarrantyExpiration!.Value,
                    i.Title,
                    i.Property?.Name ?? "-",
                    "Improvement",
                    $"/improvements/{i.Id}")),
            .. _expiringAssetWarranties
                .Where(a => a.WarrantyExpiration.HasValue)
                .Select(a => new WarrantyAlertItem(
                    a.WarrantyExpiration!.Value,
                    a.Name,
                    a.Property?.Name ?? "-",
                    "Asset",
                    $"/assets/{a.Id}/edit"))
        ];
        _expiringWarrantyItems = [.. _expiringWarrantyItems.OrderBy(x => x.WarrantyExpiration)];
        _recentImprovements = await HomeImprovementService.GetRecentAsync(5);

        var dueTasks = await MaintenanceService.GetOverdueOrUpcomingAsync(30);
        _maintenanceDue = [.. dueTasks.Select(t => new MaintenanceDueItem(t, ComputeNextDueDate(t)))];

        _categoryLabels = [.. _costByCategory.Select(x => x.CategoryName)];
        _categorySeries =
        [
            new ChartSeries<double>
            {
                Name = "Spend",
                Data = new ChartData<double>(_costByCategory.Select(x => (double)x.TotalCost).ToList())
            }
        ];

        _loading = false;
    }

    private sealed record WarrantyAlertItem(
        DateOnly WarrantyExpiration,
        string Title,
        string PropertyName,
        string Source,
        string LinkHref);

    private sealed record MaintenanceDueItem(MaintenanceTask Task, DateOnly NextDue);

    private static DateOnly ComputeNextDueDate(MaintenanceTask task)
    {
        var anchor = task.LastCompletedDate ?? DateOnly.FromDateTime(task.CreatedAt);
        return task.Interval switch
        {
            RecurrenceInterval.Days => anchor.AddDays(task.IntervalValue),
            RecurrenceInterval.Weeks => anchor.AddDays(task.IntervalValue * 7),
            RecurrenceInterval.Months => anchor.AddMonths(task.IntervalValue),
            RecurrenceInterval.Years => anchor.AddYears(task.IntervalValue),
            _ => anchor
        };
    }
}
